# Gloomberg Environment Configuration
# Copy this file to .env and fill in your values

# Zerodha Kite Connect (required for real-time data)
# KITE_API_KEY
# KITE_API_SECRET

# Financial Modeling Prep (free tier: 250 calls/day)
# FMP_API_KEY

# Finnhub (free tier: 60 calls/min)
# FINNHUB_API_KEY

# FRED - St. Louis Fed (free)
# FRED_API_KEY

# SEC EDGAR (just your email for User-Agent header)
# SEC_EDGAR_EMAIL

# Database
# DATABASE_URL (default: postgresql://localhost:5432/gloomberg)

# Redis (optional for MVP)
# REDIS_URL (default: redis://localhost:6379)

# Provider Selection
# MARKET_DATA_PROVIDER: yahoo | kite
# FUNDAMENTALS_PROVIDER: bse_filings | sec_edgar
# INDEX_PROVIDER: nse_index | yahoo_index
# ESTIMATES_PROVIDER: fmp | finnhub
# SHAREHOLDING_PROVIDER: bse_shareholding
